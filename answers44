40. Text Compression (Run-Length Encoding)
static class Task {
    public int compress(char[] c) {
        int w = 0;
        for (int i = 0; i < c.length; ) {
            char ch = c[i];
            int j = i;
            while (j < c.length && c[j] == ch) j++;
            c[w++] = ch;
            if (j - i > 1)
                for (char x : (j - i + "").toCharArray())
                    c[w++] = x;
            i = j;
        }
        return w;
    }
}
