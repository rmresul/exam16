1. 1D Cellular Automaton (Live Cells)
public static int[] gameOfLife1D(int[] cells) {
    int n = cells.length;
    int[] r = new int[n];
    for (int i = 0; i < n; i++) {
        int l = i > 0 ? cells[i-1] : 0;
        int ri = i < n-1 ? cells[i+1] : 0;
        r[i] = l ^ ri;
    }
    return r;
}
